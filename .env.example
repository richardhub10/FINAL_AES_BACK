# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# CORS (dev)
CORS_ALLOW_ALL_ORIGINS=true
# If you set CORS_ALLOW_ALL_ORIGINS=false, provide comma-separated origins:
# CORS_ALLOWED_ORIGINS=http://localhost:19006,http://127.0.0.1:19006

# Database
# Preferred for production (Render + Supabase/Postgres):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
#
# Render -> Supabase troubleshooting:
# If deploy logs show "Network is unreachable" and the host resolves to IPv6,
# set DATABASE_HOSTADDR to an IPv4 address for the same host (workaround).
# Example (Windows):
#   nslookup db.<project-ref>.supabase.co
#   # pick an IPv4 Address from the output and set it here
# DATABASE_HOSTADDR=

# AES-GCM master key (base64). Must decode to 32 bytes for AES-256.
# Generate one (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Maximum 256}))
AES_MASTER_KEY_B64=
